# ============================================
# PATRONES GEOMÉTRICOS
# ============================================

def triangulo(altura):
    for i in range(1, altura + 1):
        print("*" * i)


def cuadrado(lado):
    for i in range(lado):
        if i == 0 or i == lado - 1:
            print("*" * lado)
        else:
            print("*" + " " * (lado - 2) + "*")


def piramide(altura):
    for i in range(1, altura + 1):
        espacios = " " * (altura - i)
        estrellas = "*" * (2*i - 1)
        print(espacios + estrellas)


def menu_patrones():

    while True:

        print("\n--- PATRONES GEOMÉTRICOS ---")
        print("1. Triángulo")
        print("2. Cuadrado")
        print("3. Pirámide")
        print("4. Volver")

        opcion = input("Seleccione una opción: ")

        if opcion == "1":
            altura = int(input("Altura del triángulo: "))
            triangulo(altura)

        elif opcion == "2":
            lado = int(input("Tamaño del cuadrado: "))
            cuadrado(lado)

        elif opcion == "3":
            altura = int(input("Altura de la pirámide: "))
            piramide(altura)

        elif opcion == "4":
            break

        else:
            print("❌ Opción inválida")


# ============================================
# TEXTO ARTÍSTICO
# ============================================

def generar_banner(texto):

    ancho = len(texto) + 10

    print("╔" + "═"*ancho + "╗")
    print("║" + " "*ancho + "║")
    print("║" + texto.center(ancho) + "║")
    print("║" + " "*ancho + "║")
    print("╚" + "═"*ancho + "╝")


def marco_decorativo(texto, estilo):

    ancho = len(texto) + 4

    if estilo == 1:
        print("╔" + "═"*ancho + "╗")
        print("║ " + texto + " ║")
        print("╚" + "═"*ancho + "╝")

    elif estilo == 2:
        print("★"* (ancho+2))
        print("★ " + texto + " ★")
        print("★"* (ancho+2))

    elif estilo == 3:
        print("#"* (ancho+2))
        print("# " + texto + " #")
        print("#"* (ancho+2))

    else:
        print("Estilo no válido")


def tabla_multiplicar_visual(numero):

    print("╔════════════════════╗")
    print(f"║  TABLA DEL {numero}           ║")
    print("╠════════════════════╣")

    for i in range(1, 11):
        resultado = numero * i
        print(f"║ {numero} x {i:2} = {resultado:3}      ║")

    print("╚════════════════════╝")


def menu_texto_artistico():

    while True:

        print("\n--- TEXTO ARTÍSTICO ---")
        print("1. Crear Banner")
        print("2. Marco Decorativo")
        print("3. Tabla de Multiplicar")
        print("4. Volver")

        opcion = input("Seleccione una opción: ")

        if opcion == "1":

            texto = input("Ingrese el texto: ")
            generar_banner(texto)

        elif opcion == "2":

            texto = input("Texto: ")
            print("Estilo 1 | Estilo 2 | Estilo 3")
