            marco_decorativo(texto, estilo)

        elif opcion == "3":

            numero = int(input("Número para la tabla: "))
            tabla_multiplicar_visual(numero)

        elif opcion == "4":
            break

        else:
            print("❌ Opción inválida")


# ============================================
# ANIMACIONES
# ============================================

def crear_retraso(duracion):

    for _ in range(duracion * 200000):
        pass


def barra_progreso():

    print("\nProcesando...")

    total = 20

    for i in range(total + 1):

        llenos = "■" * i
        vacios = "-" * (total - i)

        porcentaje = int((i / total) * 100)

        print(f"[{llenos}{vacios}] {porcentaje}%", end="\r")

        crear_retraso(5)

    print(f"[{'■'*total}] 100% ¡Completo!")


def animacion_texto_movil():

    texto = input("Ingrese el texto que desea animar: ")

    for i in range(30):

        print(" " * i + texto, end="\r")

        crear_retraso(5)

    print()



def menu_animaciones():

    while True:

        print("\n--- ANIMACIONES ---")
        print("1. Barra de Progreso")
        print("2. Texto en Movimiento")
        print("3. Volver")

        opcion = input("Seleccione una opción: ")

        if opcion == "1":
            barra_progreso()

        elif opcion == "2":
            animacion_texto_movil()

        elif opcion == "3":
            break

        else:
            print("❌ Opción inválida")


